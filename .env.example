############################################################
# CreativeWriter Self-Hosted Configuration
############################################################

# === REQUIRED ===

# PostgreSQL password — use a strong random string
POSTGRES_PASSWORD=<generated-by-setup-sh>

# JWT secret — minimum 32 characters, used by all Supabase services
JWT_SECRET=<generated-by-setup-sh>

# Supabase anonymous key — HS256 JWT signed with JWT_SECRET (role=anon, expires 2039)
ANON_KEY=<generated-by-setup-sh>

# Supabase service role key — HS256 JWT signed with JWT_SECRET (role=service_role, expires 2039)
SERVICE_ROLE_KEY=<generated-by-setup-sh>

# Public-facing URL where the app is accessible
# This is used for auth redirects, CORS, and API routing
SUPABASE_PUBLIC_URL=http://localhost:3000

# Port the frontend listens on (maps to nginx container port 80)
FRONTEND_PORT=3000

# === SMTP (required for signup confirmation and password reset) ===
# Set MAILER_AUTOCONFIRM=true to skip email confirmation (dev only)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_SENDER_EMAIL=noreply@example.com
MAILER_AUTOCONFIRM=true

# === PREMIUM FEATURES (optional — leave empty to disable) ===
# If you don't configure Stripe, all users get free basic access.
# Premium features (AI Rewrite, Character Chat, Portrait Generation)
# require a Stripe subscription.

STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICING_TABLE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID_MONTHLY=
STRIPE_BASIC_PRICE_ID_YEARLY=
STRIPE_PREMIUM_PRICE_ID_MONTHLY=
STRIPE_PREMIUM_PRICE_ID_YEARLY=
STRIPE_TRIAL_DAYS=7

# AI proxy key for included AI features (optional)
DEEPSEEK_API_KEY=

# === SELF-HOSTED LICENSE KEY (optional legacy fallback) ===
# Users now enter their own license key in Settings > Premium > License Key.
# This env var is kept as a server-wide fallback — per-user keys take precedence.
# Subscribe at https://creativewriter.dev to get a license key.
# Note: Included AI (DeepSeek) is not available on self-hosted instances.
LICENSE_KEY=

# === REDIRECT URLs (used by billing portal, defaults work for localhost) ===
SUCCESS_URL=http://localhost:3000/?subscription=success

# === SUPABASE STUDIO (database admin UI) ===
# Studio starts automatically on port 54323, bound to localhost only.
# Access it at http://localhost:54323 (use SSH tunnel for remote servers).
STUDIO_PORT=54323

# === SECURITY (recommended for production) ===
# These have hardcoded defaults that work out of the box, but should be
# changed for any publicly accessible deployment.

# Realtime session secret — generate with: openssl rand -base64 32
# SECRET_KEY_BASE=

# Realtime database encryption key — generate with: openssl rand -hex 16
# DB_ENC_KEY=

# === ADVANCED ===
# POSTGRES_PORT=5432
# Disable Deno module caching (enabled by default for self-hosted).
# Set to false if functions are stable and you want faster cold starts.
# NO_MODULE_CACHE=true
